   "source": [
    "fig, ax = plt.subplots(figsize=(8,8))\n",
    "ax = fig.add_subplot(111, projection='3d')\n",
    "x=np.linspace(-np.pi,np.pi,50)\n",
    "y=x\n",
    "z=np.multiply.outer(np.cos(y),1/(1+x**2))\n",
    "\n",
    "ax.plot_surface(x, y, z, cmap='viridis')"
   ]
